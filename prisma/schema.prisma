// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Referral {
  id                          String   @id @default(uuid())
  confirmationNumber          String   @unique
  status                      ReferralStatus @default(SUBMITTED)
  formType                    FormType @default(INTERIM)
  pipIndicator                Boolean  @default(false)  // PIP checkbox from Excel (purpose TBD)
  submittedAt                 DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  deadlineDate                DateTime
  daysElapsed                 Int      @default(0)

  // Student Information
  studentName                 String
  dateOfBirth                 DateTime
  age                         Int?
  grade                       String
  classroomTeacher            String?        // General education classroom teacher name
  gender                      String?
  fosterYouth                 Boolean?
  birthplace                  String?

  // Form-type-specific metadata (JSON, used by DHH Itinerant and future forms)
  formMetadata                Json?

  // Contact Information
  parentGuardianName          String?
  homePhone                   String?
  cellPhone                   String?
  homeAddress                 String?
  city                        String?
  state                       String?
  zipCode                     String?

  // School Information
  schoolOfAttendance          String?
  schoolOfResidence           String?
  transportationSpecialEd     Boolean?

  // Language & Demographics
  nativeLanguage              String?
  englishLearner              Boolean?
  elStartDate                 DateTime?
  redesignated                Boolean?
  reclassificationDate        DateTime?
  ethnicity                   String?
  residency                   String?

  // Placement Type
  placementType               PlacementType?

  // Organizational Grouping
  silo                        Silo?

  // Program Classification (internal staff fields — not set by external submitters)
  programTrack              ProgramTrack   @default(GENERAL)
  districtOfResidence       String?
  referringParty            String?
  dateStudentStartedSchool  DateTime?
  serviceProvider           String?

  // CUM Records Workflow
  cumRequestedDate          DateTime?
  cumReceivedDate           DateTime?
  cumSentDate               DateTime?
  cumProcessedByStaffId     String?
  cumProcessedByStaff       User?          @relation("CumProcessedByStaff", fields: [cumProcessedByStaffId], references: [id])
  cumNotes                  String?

  // External System Sync (SCIP and VIP programs)
  inSEIS                    Boolean        @default(false)
  inSEISDate                DateTime?
  inAeries                  Boolean        @default(false)
  inAeriesDate              DateTime?

  // Disability Information
  primaryDisability           String?
  disabilities                Json?    // Additional disabilities stored as JSON

  // Special Education Dates
  spedEntryDate               DateTime?
  interimPlacementReviewDate  DateTime?
  triennialDue                DateTime?

  // Last Placement Information
  lastPlacementSchool         String?
  lastPlacementDistrict       String?
  lastPlacementCounty         String?
  lastPlacementState          String?
  lastPlacementPhone          String?
  lastPlacementContactPerson  String?

  // Special Education Services (stored as JSON array)
  specialEdServices           Json?
  percentageOutsideGenEd      Int?

  // District Authorization
  leaRepresentativeName       String?
  leaRepresentativePosition   String?
  submittedByEmail            String?

  // Packet Alignment Fields
  currentIepDate              DateTime?
  currentPsychoReportDate     DateTime?
  nonSeisIep                  Boolean  @default(false)

  // Additional Information
  additionalComments          String?

  // NEW: Rejection tracking
  rejectionReason             String?
  missingItems                Json?

  // NEW: Review tracking
  lastReviewedAt              DateTime?
  lastReviewedBy              String?

  // Relationships
  documents                   Document[]
  documentChecklistItems      DocumentChecklistItem[]
  releaseOfInformation        ReleaseOfInformationMetadata?
  statusHistory               StatusHistory[]
  notes                       Note[]
  assignedToStaffId           String?
  assignedToStaff             User?     @relation("AssignedReferrals", fields: [assignedToStaffId], references: [id])
  submittedByUserId           String?
  submittedByUser             User?     @relation("SubmittedReferrals", fields: [submittedByUserId], references: [id])
  placement                   StudentPlacement? @relation("ReferralPlacement")

  @@index([status])
  @@index([submittedAt])
  @@index([deadlineDate])
  @@index([confirmationNumber])
  @@index([submittedByUserId])
  @@index([programTrack])
  @@index([districtOfResidence])
  @@index([silo])
}

model Document {
  id              String   @id @default(uuid())
  referralId      String
  referral        Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  documentType    String   // 'studentRegistration', 'homeLanguageSurvey', etc.
  fileName        String
  filePath        String   // Supabase Storage path
  fileSize        Int
  mimeType        String

  uploadedAt      DateTime @default(now())
  uploadedBy      String?

  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?

  @@index([referralId])
  @@index([documentType])
}

model DocumentChecklistItem {
  id              String            @id @default(uuid())
  referralId      String
  referral        Referral          @relation(fields: [referralId], references: [id], onDelete: Cascade)

  type            ChecklistItemType
  required        Boolean           @default(true)
  status          ChecklistStatus   @default(PENDING)
  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String?
  version         Int               @default(1)

  files           DocumentFile[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([referralId])
  @@index([type])
  @@index([status])
}

model DocumentFile {
  id               String               @id @default(uuid())
  checklistItemId  String
  checklistItem    DocumentChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  fileName         String
  filePath         String
  fileSize         Int
  mimeType         String

  uploadedAt       DateTime             @default(now())
  uploadedBy       String?

  @@index([checklistItemId])
}

model ReleaseOfInformationMetadata {
  id                String   @id @default(uuid())
  referralId        String   @unique
  referral          Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  disclosingName    String?
  disclosingAddress String?
  disclosingPhone   String?
  disclosingFax     String?
  receivingName     String?
  receivingAddress  String?
  receivingPhone    String?
  receivingFax      String?

  purpose           String?
  informationRequested String?

  effectiveDate     DateTime?
  expirationDate    DateTime?
  signedBy          String?
  signedDate        DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model StatusHistory {
  id          String   @id @default(uuid())
  referralId  String
  referral    Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  fromStatus  ReferralStatus?
  toStatus    ReferralStatus
  changedAt   DateTime @default(now())
  changedBy   String
  reason      String?

  @@index([referralId])
  @@index([changedAt])
}

model Note {
  id          String   @id @default(uuid())
  referralId  String
  referral    Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  noteType    NoteType
  content     String
  isImportant Boolean  @default(false)

  createdAt   DateTime @default(now())
  createdBy   String

  @@index([referralId])
  @@index([createdAt])
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  name              String
  role              UserRole
  roleOptionId      String?

  // Authentication (Supabase Auth)
  supabaseUserId    String?        @unique

  // Profile
  phoneNumber       String?
  organization      String?
  jobTitle          String?

  // Status
  isActive          Boolean        @default(true)
  lastLoginAt       DateTime?

  // Metadata
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  createdBy         String?

  // Relationships
  roleOption        UserRoleOption?         @relation(fields: [roleOptionId], references: [id], onDelete: SetNull)
  referralsAssigned Referral[]              @relation("AssignedReferrals")
  referralsSubmitted Referral[]             @relation("SubmittedReferrals")
  cumProcessedReferrals Referral[]          @relation("CumProcessedByStaff")
  ordersRequested   Order[]                 @relation("OrderRequestor")
  ordersApproved    Order[]                 @relation("OrderApprover")
  orderStatusHistory OrderStatusHistory[]   @relation("OrderStatusHistoryChangedBy")
  orderNotes        OrderNote[]             @relation("OrderNoteCreatedBy")

  @@index([role])
  @@index([roleOptionId])
  @@index([supabaseUserId])
  @@index([email])
}

model UserRoleOption {
  id          String    @id @default(uuid())
  name        String    @unique
  baseRole    UserRole
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  users       User[]

  @@index([baseRole])
}

// ==================== ORDER MANAGEMENT MODELS ====================

model Order {
  id                  String         @id @default(uuid())
  orderNumber         String         @unique
  status              OrderStatus    @default(NEW)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Order Details
  justification       String
  totalEstimatedPrice Decimal        @default(0) @db.Decimal(10, 2)
  totalActualPrice    Decimal?       @db.Decimal(10, 2)

  // Requestor Information
  requestorId         String
  requestor           User           @relation("OrderRequestor", fields: [requestorId], references: [id])
  schoolSite          String

  // Approval Workflow
  approverId          String?
  approver            User?          @relation("OrderApprover", fields: [approverId], references: [id])
  approvedAt          DateTime?
  rejectionReason     String?
  lastStatusUpdate    DateTime?

  // Tracking
  purchaseOrderNumber String?
  vendor              String?
  trackingNumber      String?
  expectedDelivery    DateTime?
  receivedDate        DateTime?

  // Budget Tracking (optional for v1)
  budgetCategory      String?
  fiscalYear          String?

  // Protocol/Assessment orders
  orderType             OrderType      @default(SUPPLY)
  assessmentCategoryId  String?
  assessmentCategory    AssessmentCategory? @relation(fields: [assessmentCategoryId], references: [id])

  // Relationships
  items               OrderItem[]
  statusHistory       OrderStatusHistory[]
  notes               OrderNote[]
  attachments         OrderAttachment[]

  @@index([status])
  @@index([requestorId])
  @@index([createdAt])
  @@index([orderNumber])
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  itemName        String
  itemLink        String?
  estimatedPrice  Decimal  @db.Decimal(10, 2)
  actualPrice     Decimal? @db.Decimal(10, 2)
  quantity        Int      @default(1)

  // Protocol orders link items to catalog tests
  assessmentTestId    String?
  assessmentTest      AssessmentTest? @relation(fields: [assessmentTestId], references: [id])

  createdAt       DateTime @default(now())

  @@index([orderId])
}

model OrderStatusHistory {
  id              String      @id @default(uuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status          OrderStatus
  createdAt       DateTime    @default(now())
  changedByUserId String
  changedBy       User        @relation("OrderStatusHistoryChangedBy", fields: [changedByUserId], references: [id])
  notes           String?

  @@index([orderId])
  @@index([createdAt])
}

model OrderNote {
  id            String   @id @default(uuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  content       String
  noteType      NoteType @default(GENERAL)

  createdAt     DateTime @default(now())
  createdById   String
  createdBy     User     @relation("OrderNoteCreatedBy", fields: [createdById], references: [id])

  @@index([orderId])
  @@index([createdAt])
}

model OrderAttachment {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fileName    String
  filePath    String
  fileSize    Int
  mimeType    String
  description String?

  uploadedAt  DateTime @default(now())
  uploadedBy  String

  @@index([orderId])
}

// ==================== ENUMS ====================

enum ReferralStatus {
  SUBMITTED
  UNDER_REVIEW
  MISSING_DOCUMENTS
  PENDING_ADDITIONAL_INFO
  PENDING_APPROVAL
  APPROVED
  ACCEPTED_AWAITING_PLACEMENT
  REJECTED
  ON_HOLD
  COMPLETED
  NOT_ENROLLING
  WITHDRAWN
}

enum ProgramTrack {
  GENERAL
  BEHAVIOR
  DHH
  SCIP
  VIP
}

enum Silo {
  ASD
  SD
  NC
  DHH
  MD
  OT
}

enum PlacementType {
  FRA
  SDC
}

enum UserRole {
  EXTERNAL_ORG
  TEACHER
  SPED_STAFF
  ADMIN
  SUPER_ADMIN
}

enum NoteType {
  GENERAL
  PHONE_CALL
  EMAIL
  MEETING
  DOCUMENT_RECEIVED
  DECISION_MADE
}

enum OrderStatus {
  NEW
  SHIPPED
  RECEIVED
  COMPLETED
  CANCELLED
}

enum OrderType {
  SUPPLY
  PROTOCOL_ASSESSMENT
}

enum FormType {
  INTERIM
  DHH_ITINERANT
  LEVEL_II
}

enum ProgramSilo {
  ASD_ELEM
  ASD_MIDHS
  SD
  NC
  DHH
  ATP
  MD
}


enum SessionType {
  AM
  PM
  FULL_DAY
  PERIOD_ATTENDANCE
  SELF_CONTAINED
}

enum StaffRole {
  TEACHER
  CLASS_PARA
  ONE_TO_ONE_PARA
  INTERPRETER
  SIGNING_PARA
  LVN
}

enum EnrollmentStatus {
  ACTIVE
  REFERRAL_PENDING
  REFERRAL_NOT_RECEIVED
  REFERRAL_ON_HOLD
  PLACED_NOT_IN_SYSTEMS
  HOME_INSTRUCTION
  RTD_IN_PROGRESS
  EXITED
}

enum TransferReason {
  GRADE_PROMOTION
  CASELOAD_BALANCE
  BEHAVIOR_PLACEMENT_CHANGE
  PROGRAM_CHANGE
  PARENT_REQUEST
  OTHER
}

enum ChecklistItemType {
  STUDENT_REGISTRATION
  HOME_LANGUAGE_SURVEY
  IMMUNIZATION_RECORD
  RELEASE_OF_INFORMATION
  CURRENT_IEP
  PSYCHO_ED_REPORT
  INTERIM_PLACEMENT_FORM
  TRANSCRIPTS
  RATIONALE_FOR_REFERRAL
  MULTIDISCIPLINARY_TEAM_REPORT
  BEHAVIOR_ASSESSMENT
  INTERVENTION_STRATEGIES
  CURRENT_ACADEMIC_ASSESSMENT
  REPORTS_OTHER_AGENCIES
  CURRENT_BEHAVIOR_PLAN
  IEP_DOCUMENTATION
  PRIMARY_MODE_OF_LEARNING
  PRESCRIBED_MEDICATION
  AUDIOGRAM_CHART
  DHH_REFERRAL_REQUEST
  ACCOMMODATIONS_MODIFICATIONS
  AUDIOLOGY_REPORT
}

enum ChecklistStatus {
  PENDING
  ACCEPTED
  REJECTED
  MISSING
}

model ReferralDraft {
  id          String   @id @default(uuid())
  draftNumber String   @unique
  email       String
  formType    FormType
  formData    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime

  @@index([email])
  @@index([draftNumber])
  @@index([expiresAt])
}

model EmailSettings {
  id                       String   @id @default(cuid())
  orderNotifyEmails        String[]
  referralNotifyEmails     String[]
  cumReminderDays          Int      @default(10)
  seisAeriesReminderDays   Int      @default(5)
  updatedAt                DateTime @updatedAt
  updatedById              String?
}

model AssessmentCategory {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  isActive    Boolean           @default(true)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tests       AssessmentTest[]
  orders      Order[]

  @@index([isActive])
}

model AssessmentVendor {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  website     String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tests       AssessmentTest[]

  @@index([isActive])
}

model AssessmentTest {
  id                  String             @id @default(uuid())
  name                String
  vendorId            String
  vendor              AssessmentVendor   @relation(fields: [vendorId], references: [id])
  categoryId          String
  category            AssessmentCategory @relation(fields: [categoryId], references: [id])
  purchaseUrl         String?
  estimatedPrice      Decimal            @default(0) @db.Decimal(10, 2)
  isPhysical          Boolean            @default(true)
  isActive            Boolean            @default(true)
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  orderItems          OrderItem[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([isActive])
}

// ==================== PLACEMENT MODELS ====================

model Site {
  id         String      @id @default(uuid())
  name       String      @unique
  district   String?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  classrooms Classroom[]

  @@index([isActive])
}

model StaffMember {
  id                    String     @id @default(uuid())
  name                  String
  role                  StaffRole
  positionControlNumber String?
  credentials           String?
  isVacancy             Boolean    @default(false)
  isActive              Boolean    @default(true)
  schoolYear            String

  // For CLASS_PARA, INTERPRETER, SIGNING_PARA, LVN: linked to a classroom
  classroomId           String?
  classroom             Classroom? @relation("ClassroomParas", fields: [classroomId], references: [id])

  // For ONE_TO_ONE_PARA: linked to a specific student
  oneToOneStudentId     String?           @unique
  oneToOneStudent       StudentPlacement? @relation("StudentOneToOnePara", fields: [oneToOneStudentId], references: [id])

  // Back-reference: classrooms where this person is the teacher
  taughtClassrooms      Classroom[] @relation("ClassroomTeacher")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([schoolYear])
  @@index([isActive])
  @@index([classroomId])
}

model Classroom {
  id                    String       @id @default(uuid())
  classroomNumber       String?
  programSilo           ProgramSilo
  siteId                String
  site                  Site         @relation(fields: [siteId], references: [id])
  gradeStart            String       @default("K")
  gradeEnd              String       @default("K")
  sessionNumber         String?
  sessionType           SessionType
  positionControlNumber String?
  credentials           String?
  maxCapacity           Int?
  schoolYear            String
  isOpenPosition        Boolean      @default(false)

  // Teacher assignment (FK on Classroom side to avoid circular dependency)
  teacherId             String?
  teacher               StaffMember? @relation("ClassroomTeacher", fields: [teacherId], references: [id])

  // Paras and other staff assigned to this classroom
  paras                 StaffMember[] @relation("ClassroomParas")

  // Student placements
  studentPlacements     StudentPlacement[] @relation("ClassroomPlacements")

  // Transfer events (origin and destination)
  transfersFrom         TransferEvent[] @relation("TransferFromClassroom")
  transfersTo           TransferEvent[] @relation("TransferToClassroom")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programSilo])
  @@index([siteId])
  @@index([schoolYear])
  @@index([teacherId])
}

model StudentPlacement {
  id                  String           @id @default(uuid())
  referralId          String           @unique
  referral            Referral         @relation("ReferralPlacement", fields: [referralId], references: [id])

  studentNameFirst    String
  studentNameLast     String
  dateOfBirth         DateTime
  grade               String
  districtOfResidence String?
  disabilityCodes     String[]
  primaryDisability   String?

  classroomId         String?
  classroom           Classroom?       @relation("ClassroomPlacements", fields: [classroomId], references: [id])

  enrollmentStatus    EnrollmentStatus @default(REFERRAL_PENDING)
  schoolYear          String

  requires1to1        Boolean          @default(false)
  oneToOnePara        StaffMember?     @relation("StudentOneToOnePara")

  seisConfirmed       Boolean          @default(false)
  seisConfirmedAt     DateTime?
  seisConfirmedBy     String?
  aeriesConfirmed     Boolean          @default(false)
  aeriesConfirmedAt   DateTime?
  aeriesConfirmedBy   String?

  ageOutDate          DateTime?

  notes               String?

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  transferEvents      TransferEvent[]  @relation("StudentTransfers")
  rtdChecklist        RTDChecklist?    @relation("PlacementRTD")
  transportRecord     TransportRecord? @relation("PlacementTransport")
  auditLogs           PlacementAuditLog[] @relation("StudentAuditLogs")

  @@index([classroomId])
  @@index([enrollmentStatus])
  @@index([schoolYear])
}

model TransferEvent {
  id              String           @id @default(uuid())
  studentId       String
  student         StudentPlacement @relation("StudentTransfers", fields: [studentId], references: [id])
  fromClassroomId String?
  fromClassroom   Classroom?       @relation("TransferFromClassroom", fields: [fromClassroomId], references: [id])
  toClassroomId   String?
  toClassroom     Classroom?       @relation("TransferToClassroom", fields: [toClassroomId], references: [id])
  effectiveDate   DateTime
  reason          TransferReason
  initiatedBy     String
  notes           String?
  createdAt       DateTime         @default(now())

  @@index([studentId])
  @@index([effectiveDate])
}

model RTDChecklist {
  id                      String           @id @default(uuid())
  studentId               String           @unique
  student                 StudentPlacement @relation("PlacementRTD", fields: [studentId], references: [id])

  dorNotified             Boolean @default(false)
  dorNotifiedAt           DateTime?
  dorNotifiedBy           String?

  parentNotified          Boolean @default(false)
  parentNotifiedAt        DateTime?
  parentNotifiedBy        String?

  secondStaffingCompleted Boolean @default(false)
  secondStaffingAt        DateTime?
  secondStaffingBy        String?

  transitionIepHeld       Boolean @default(false)
  transitionIepAt         DateTime?
  transitionIepBy         String?

  packetCompleted         Boolean @default(false)
  packetCompletedAt       DateTime?
  packetCompletedBy       String?

  packetSignedScanned     Boolean @default(false)
  packetSignedAt          DateTime?
  packetSignedBy          String?

  aeriesExitCompleted     Boolean @default(false)
  aeriesExitAt            DateTime?
  aeriesExitBy            String?

  seisExitCompleted       Boolean @default(false)
  seisExitAt              DateTime?
  seisExitBy              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransportRecord {
  id                  String           @id @default(uuid())
  studentId           String           @unique
  student             StudentPlacement @relation("PlacementTransport", fields: [studentId], references: [id])

  busNumber           String?
  transportType       String?
  amPmFlag            String?
  specialTransportNotes String?

  isWheelchair        Boolean @default(false)
  needsCarSeat        Boolean @default(false)
  needsSafetyVest     Boolean @default(false)
  needsSafetyLock     Boolean @default(false)
  needsBusAide        Boolean @default(false)
  riderAtHome         Boolean @default(false)
  reducedDaySchedule  Boolean @default(false)
  transportPending    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlacementAuditLog {
  id         String            @id @default(uuid())
  entityType String
  entityId   String
  field      String
  oldValue   String?
  newValue   String?
  changedBy  String
  changedAt  DateTime          @default(now())

  studentId  String?
  student    StudentPlacement? @relation("StudentAuditLogs", fields: [studentId], references: [id])

  @@index([entityType, entityId])
  @@index([studentId])
  @@index([changedAt])
}

// ==================== SANDBOX / PLANNING MODELS ====================

model PlanningDraft {
  id              String                  @id @default(uuid())
  name            String
  description     String?
  schoolYear      String
  createdBy       String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  publishedAt     DateTime?
  isPublished     Boolean                 @default(false)

  draftClassrooms   DraftClassroom[]
  draftPlacements   DraftStudentPlacement[]
}

model DraftClassroom {
  id                    String                  @id @default(uuid())
  draftId               String
  draft                 PlanningDraft           @relation(fields: [draftId], references: [id], onDelete: Cascade)
  sourceClassroomId     String?
  programSilo           ProgramSilo
  siteId                String
  gradeStart            String                  @default("K")
  gradeEnd              String                  @default("K")
  sessionType           SessionType
  positionControlNumber String?
  credentials           String?
  teacherName           String?
  isOpenPosition        Boolean                 @default(false)

  draftPlacements DraftStudentPlacement[]

  @@index([draftId])
}

model DraftStudentPlacement {
  id                String          @id @default(uuid())
  draftId           String
  draft             PlanningDraft   @relation(fields: [draftId], references: [id], onDelete: Cascade)
  sourcePlacementId String?
  draftClassroomId  String?
  draftClassroom    DraftClassroom? @relation(fields: [draftClassroomId], references: [id], onDelete: SetNull)
  studentNameFirst  String
  studentNameLast   String
  grade             String
  primaryDisability String?
  requires1to1      Boolean         @default(false)

  @@index([draftId])
  @@index([draftClassroomId])
}
